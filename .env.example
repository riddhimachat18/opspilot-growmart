# Copy this to .env and fill in your values

# ── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GOOGLE_API_KEY=   # same value as GEMINI_API_KEY

# ── Airtable (CRM leads) ──────────────────────────────────────────────────────
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=Leads
AIRTABLE_VIEW_ID=

# ── Google Calendar ───────────────────────────────────────────────────────────
# Local dev — point to your service account JSON file:
GOOGLE_SERVICE_ACCOUNT_FILE=/absolute/path/to/service-account-key.json
# Cloud deploy (Render) — paste the FULL JSON contents as a single-line string:
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_CALENDAR_ID=primary

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role key — never expose to frontend

# ── CORS (backend) ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Local: leave blank (defaults to localhost)
# Production: set to your Vercel URL
ALLOWED_ORIGINS=https://your-app.vercel.app
